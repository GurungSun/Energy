        </div>
    </div>
</div>

@inject HttpClient Http

<button class="btn btn-danger" @onclick="SendFlashRequest">
    FLASH PI LED
</button>

@code {
    private string statusMessage = "Ready.";

    private async Task SendFlashRequest()
    {
        statusMessage = "Sending command...";

        // 1. The URL (The Address of your Pi)
        string piUrl = "http://10.1.18.1:5000/flash";

        // 2. The Payload (The JSON 'Package' your teacher wants)
        // This creates: {"command": "start_flash"}
        var payload = new { command = "start_flash" };

        try
        {
            // 3. The POST Request
            // This sends the verb (POST), the address (piUrl), and the package (payload)
            var response = await Http.PostAsJsonAsync(piUrl, payload);

            if (response.IsSuccessStatusCode)
            {
                // This is where we handle the '200' code from the Pi
                statusMessage = "Success! LED is flashing.";
            }
            else
            {
                // This handles errors (like 400 or 404)
                statusMessage = $"Pi error: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            // This handles network issues (like the Pi being turned off)
            statusMessage = "Error: Could not find the Pi on the network.";
            Console.WriteLine(ex.Message);
        }
    }
}


